#include <Arduino.h>#include <Arduino.h>
#include <micro_ros_platformio.h>

#include <rcl/rcl.h>
#include <rclc/rclc.h>
#include <rclc/executor.h>
#include <geometry_msgs/msg/twist.h>

#if !defined(MICRO_ROS_TRANSPORT_ARDUINO_SERIAL)
#error This example is only available for Arduino framework with serial transport.
#endif

// --- ANPASSEN: müssen experimentell bestimmt werden ---
#define MOTOR_TX_PIN   17
#define MOTOR_BAUD     9600
#define MOTOR_ID_LEFT  0
#define MOTOR_ID_RIGHT 1
#define WHEEL_BASE     0.17f    // Radabstand in m, ausmessen
#define MAX_SPEED_MS   0.15f    // schnellste Fahrt in m/s
#define MAX_PARAM      1000     // param-Wert bei MAX_SPEED_MS
#define INVERT_RIGHT   true     // gespiegelt eingebauter Motor
// ------------------------------------------------------

#define MODE_CONTINUOUS 1
#define CMD_TIMEOUT_MS  500

rcl_subscription_t subscriber;
geometry_msgs__msg__Twist msg;
rclc_executor_t executor;
rclc_support_t support;
rcl_allocator_t allocator;
rcl_node_t node;

unsigned long last_cmd = 0;

#define RCCHECK(fn) { rcl_ret_t temp_rc = fn; if((temp_rc != RCL_RET_OK)){error_loop();}}
#define RCSOFTCHECK(fn) { rcl_ret_t temp_rc = fn; if((temp_rc != RCL_RET_OK)){}}

void error_loop() {
  while(1) { delay(100); }
}

void sendMotorCommand(uint8_t id, uint8_t mode, uint8_t dir, uint16_t param) {
  Serial2.write((uint8_t)0xAA);
  Serial2.write(id);
  Serial2.write(mode);
  Serial2.write(dir);
  Serial2.write((uint8_t)(param & 0xFF));         // Low Byte
  Serial2.write((uint8_t)((param >> 8) & 0xFF));  // High Byte
}

// Geschwindigkeit in m/s -> Richtung + param
void setWheel(uint8_t id, float speed, bool invert) {
  if (invert) speed = -speed;

  uint8_t dir = (speed >= 0.0f) ? 0 : 1;
  float mag = fabsf(speed);

  if (mag > MAX_SPEED_MS) mag = MAX_SPEED_MS;

  uint16_t param = (uint16_t)((mag / MAX_SPEED_MS) * MAX_PARAM);
  sendMotorCommand(id, MODE_CONTINUOUS, dir, param);
}

void stopMotors() {
  sendMotorCommand(MOTOR_ID_LEFT,  MODE_CONTINUOUS, 0, 0);
  sendMotorCommand(MOTOR_ID_RIGHT, MODE_CONTINUOUS, 0, 0);
}

void cmd_vel_callback(const void * msgin) {
  const geometry_msgs__msg__Twist * m = (const geometry_msgs__msg__Twist *)msgin;

  float v = m->linear.x;
  float w = m->angular.z;

  float v_left  = v - w * (WHEEL_BASE / 2.0f);
  float v_right = v + w * (WHEEL_BASE / 2.0f);

  setWheel(MOTOR_ID_LEFT,  v_left,  false);
  setWheel(MOTOR_ID_RIGHT, v_right, INVERT_RIGHT);

  last_cmd = millis();
}

void setup() {
  Serial.begin(115200);
  set_microros_serial_transports(Serial);

  Serial2.begin(MOTOR_BAUD, SERIAL_8N1, -1, MOTOR_TX_PIN);

  delay(2000);

  allocator = rcl_get_default_allocator();
  RCCHECK(rclc_support_init(&support, 0, NULL, &allocator));
  RCCHECK(rclc_node_init_default(&node, "esp32_robot_node", "", &support));

  RCCHECK(rclc_subscription_init_default(
    &subscriber,
    &node,
    ROSIDL_GET_MSG_TYPE_SUPPORT(geometry_msgs, msg, Twist),
    "cmd_vel"));

  RCCHECK(rclc_executor_init(&executor, &support.context, 1, &allocator));
  RCCHECK(rclc_executor_add_subscription(
    &executor, &subscriber, &msg, &cmd_vel_callback, ON_NEW_DATA));

  stopMotors();
  last_cmd = millis();
}

void loop() {
  RCSOFTCHECK(rclc_executor_spin_some(&executor, RCL_MS_TO_NS(100)));

  // Watchdog: stoppen, wenn keine Befehle mehr kommen
  if (millis() - last_cmd > CMD_TIMEOUT_MS) {
    stopMotors();
    last_cmd = millis();
  }

  delay(10);
}
