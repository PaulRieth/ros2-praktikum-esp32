#include <Arduino.h>
#include <micro_ros_platformio.h>

#include <rcl/rcl.h>
#include <rclc/rclc.h>
#include <rclc/executor.h>
#include <geometry_msgs/msg/twist.h>
#include <sensor_msgs/msg/range.h>

#include <WiFi.h>
#include "secrets.h"

// --- Hardware-Parameter (gemessen) ---
#define MOTOR_TX_PIN     17
#define MOTOR_BAUD       9600
#define MOTOR_ID_LEFT    1
#define MOTOR_ID_RIGHT   2

#define WHEEL_DIAMETER   0.041f    // m
#define WHEEL_BASE       0.166f    // m, Mitte zu Mitte
#define STEPS_PER_REV    2048.0f

// Vorwaerts: linker Motor dir=1, rechter dir=0 (Motor gespiegelt verbaut)
#define DIR_LEFT_FWD     1
#define DIR_RIGHT_FWD    0

#define MIN_PARAM        3         // schnellster Schritt
#define MAX_PARAM        200       // langsamste sinnvolle Fahrt
// --------------------------------------

#define MODE_CONTINUOUS  1
#define CMD_TIMEOUT_MS   500

#define TRIG_PIN 26
#define ECHO_PIN 25

// v = (1000 / param) / STEPS_PER_REV * Radumfang
// => param = 1000 * Radumfang / (STEPS_PER_REV * v)
const float WHEEL_CIRC = WHEEL_DIAMETER * PI;
const float PARAM_CONST = 1000.0f * WHEEL_CIRC / STEPS_PER_REV;   // ca. 0.0629

rcl_subscription_t subscriber;
geometry_msgs__msg__Twist msg;
rclc_executor_t executor;
rclc_support_t support;
rcl_allocator_t allocator;
rcl_node_t node;


rcl_publisher_t range_pub;
sensor_msgs__msg__Range range_msg;
rcl_timer_t range_timer;

unsigned long last_cmd = 0;

#define RCCHECK(fn) { rcl_ret_t temp_rc = fn; if((temp_rc != RCL_RET_OK)){error_loop();}}
#define RCSOFTCHECK(fn) { rcl_ret_t temp_rc = fn; if((temp_rc != RCL_RET_OK)){}}

void error_loop() {
  while(1) { delay(100); }
}

void sendMotorCommand(uint8_t id, uint8_t mode, uint8_t dir, uint16_t param) {
  Serial2.write((uint8_t)0xAA);
  Serial2.write(id);
  Serial2.write(mode);
  Serial2.write(dir);
  Serial2.write((uint8_t)((param >> 8) & 0xFF));   // High Byte zuerst
  Serial2.write((uint8_t)(param & 0xFF));
}

// Radgeschwindigkeit in m/s -> Motorbefehl
void setWheel(uint8_t id, float speed, uint8_t dir_forward) {
  float mag = fabsf(speed);

  // langsamer als MAX_PARAM erlaubt -> stehenbleiben
  if (mag < PARAM_CONST / MAX_PARAM) {
    sendMotorCommand(id, MODE_CONTINUOUS, dir_forward, 0);
    return;
  }

  uint8_t dir = (speed >= 0.0f) ? dir_forward : (dir_forward ? 0 : 1);

  float p = PARAM_CONST / mag;
  if (p < MIN_PARAM) p = MIN_PARAM;
  if (p > MAX_PARAM) p = MAX_PARAM;

  sendMotorCommand(id, MODE_CONTINUOUS, dir, (uint16_t)(p + 0.5f));
}

float measureDistance() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  // Timeout 30 ms entspricht gut 5 m
  unsigned long dauer = pulseIn(ECHO_PIN, HIGH, 30000);

  if (dauer == 0) return -1.0f;          // nichts empfangen
  return (dauer * 0.000343f) / 2.0f;     // Sekunden -> m, Hin- und Rueckweg
}

void range_timer_callback(rcl_timer_t * timer, int64_t last_call_time) {
  RCLC_UNUSED(last_call_time);
  if (timer == NULL) return;

  float d = measureDistance();

  // ungueltige Messung als "unendlich weit" melden
  range_msg.range = (d < 0.0f) ? range_msg.max_range + 1.0f : d;

  RCSOFTCHECK(rcl_publish(&range_pub, &range_msg, NULL));
}

void stopMotors() {
  sendMotorCommand(MOTOR_ID_LEFT,  MODE_CONTINUOUS, DIR_LEFT_FWD,  0);
  sendMotorCommand(MOTOR_ID_RIGHT, MODE_CONTINUOUS, DIR_RIGHT_FWD, 0);
}

void cmd_vel_callback(const void * msgin) {
  const geometry_msgs__msg__Twist * m = (const geometry_msgs__msg__Twist *)msgin;

  float v = m->linear.x;
  float w = m->angular.z;

  float v_left  = v - w * (WHEEL_BASE / 2.0f);
  float v_right = v + w * (WHEEL_BASE / 2.0f);

  setWheel(MOTOR_ID_LEFT,  v_left,  DIR_LEFT_FWD);
  setWheel(MOTOR_ID_RIGHT, v_right, DIR_RIGHT_FWD);

  last_cmd = millis();
}

void setup() {
  Serial.begin(115200);

  IPAddress agent_ip(AGENT_IP_0, AGENT_IP_1, AGENT_IP_2, AGENT_IP_3);
  set_microros_wifi_transports(WIFI_SSID, WIFI_PASSWORD, agent_ip, AGENT_PORT);

  Serial2.begin(MOTOR_BAUD, SERIAL_8N1, -1, MOTOR_TX_PIN);

  delay(2000);

  allocator = rcl_get_default_allocator();
  RCCHECK(rclc_support_init(&support, 0, NULL, &allocator));
  RCCHECK(rclc_node_init_default(&node, "esp32_robot_node", "", &support));

  RCCHECK(rclc_subscription_init_default(
    &subscriber,
    &node,
    ROSIDL_GET_MSG_TYPE_SUPPORT(geometry_msgs, msg, Twist),
    "cmd_vel"));

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  RCCHECK(rclc_publisher_init_default(
    &range_pub,
    &node,
    ROSIDL_GET_MSG_TYPE_SUPPORT(sensor_msgs, msg, Range),
    "range"));

  RCCHECK(rclc_timer_init_default(
    &range_timer, &support, RCL_MS_TO_NS(100), range_timer_callback));

  // Konstante Felder der Range-Nachricht
  range_msg.radiation_type = sensor_msgs__msg__Range__ULTRASOUND;
  range_msg.field_of_view = 0.26f;    // ca. 15 Grad
  range_msg.min_range = 0.02f;
  range_msg.max_range = 4.0f;
  range_msg.header.frame_id.data = (char *)"ultrasonic";
  range_msg.header.frame_id.size = 10;
  range_msg.header.frame_id.capacity = 11;

  RCCHECK(rclc_executor_init(&executor, &support.context, 2, &allocator));
  RCCHECK(rclc_executor_add_subscription(
    &executor, &subscriber, &msg, &cmd_vel_callback, ON_NEW_DATA));
  RCCHECK(rclc_executor_add_timer(&executor, &range_timer));

  stopMotors();
  last_cmd = millis();
  }

  void loop() {
  RCSOFTCHECK(rclc_executor_spin_some(&executor, RCL_MS_TO_NS(100)));

  if (millis() - last_cmd > CMD_TIMEOUT_MS) {
    stopMotors();
    last_cmd = millis();
  }

  delay(10);
  }
